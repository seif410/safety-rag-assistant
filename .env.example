# --- Required API keys ---
NVIDIA_API_KEY=your_nvidia_api_key
GOOGLE_API_KEY=your_google_api_key
COHERE_API_KEY=your_cohere_api_key

# --- Qdrant vector store ---
# For local (non-Docker) runs use localhost. Under docker-compose the api
# service overrides this to http://qdrant:6333 (see docker-compose.yml).
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=safety-docs

# --- Optional overrides (defaults shown in app/config.py) ---
# EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
# COHERE_RERANK_MODEL=rerank-v4.0-pro
# CHAT_MODEL=gemini-2.5-flash
# CHAT_MODEL_PROVIDER=google_genai
# EMBEDDING_BATCH_SIZE=50
# EMBEDDING_RETRY_MIN_SECONDS=10
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=200
# RETRIEVAL_K=6
# TOP_N=4
